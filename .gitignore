__pycache__/
*.py[cod]
*$py.class
.venv/
v4_outputs/          # legacy location — engine run store now lives in output/runs/ (ignored via /output/*)
output/runs/
data/
archive/
.ipynb_checkpoints/

# Proprietary input data — never commit
input_data/

# Local Claude Code config
.claude/

# Per-run experiment scratch outputs
experiment_results*.csv

# scratch run logs
scratch_*.log

# run-stamped pricing snapshots (local audit trail)
/output/DISCOUNT_PLAN/pricing/history/

# generated deliverables (regenerated from runs; may contain proprietary data)
# everything Claude generates lands in output/ — kept local, except its README.
# output/DISCOUNT_PLAN stays TRACKED (weekly-tracker config + reports were committed).
/output/*
!/output/README.md
!/output/DISCOUNT_PLAN
!/output/DISCOUNT_PLAN/**
/output/DISCOUNT_PLAN/pricing/history/
ACTION_PLAN_all_products.*
